{
  "name": "arstraverse",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w web",
    "dev": "npm run dev -w web",
    "lint": "npm run lint -w web",
    "start": "npm run start -w web",
    "postinstall": "npm run generate -w @repo/db",
    "db:generate": "npm run db:generate -w @repo/db",
    "db:migrate": "npm run db:migrate -w @repo/db",
    "db:push": "npm run db:push -w @repo/db",
    "db:studio": "npm run db:studio -w @repo/db",
    "test:e2e": "playwright test",
    "test:e2e:kg": "playwright test e2e/kg",
    "test:e2e:edge-motion": "playwright test e2e/kg/edge-cdt-animation.unit.spec.ts e2e/kg/edge-motion-classification.unit.spec.ts e2e/kg/classify-edge-motion.integration.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "mcp:i": "sudo npx @modelcontextprotocol/inspector",
    "kg:align": "tsx scripts/kg-alignment-agent/index.ts"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.13.0",
    "dotenv": "^16.6.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.2",
    "typescript": "^5.4.2"
  },
  "packageManager": "npm@11.12.1",
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@swc/core-linux-x64-gnu": "1.15.33"
  },
  "overrides": {
    "@langchain/core": "^1.1.47",
    "cookie": "^0.7.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1"
  }
}
